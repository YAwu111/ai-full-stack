<swiper url="#" class="section hero white" indicator-dots="{{true}}" indicator-active-color="black" autoplay="true" interval="3000">
  <block wx:for="{{slides}}" wx:key="id">
    <swiper-item >
      <image src="{{item.image}}" class="slide-img"/>
      <view class="content center">
        <view class="header">{{item.header}}</view>
        <view class="sub_header">{{item.sub_header}}</view>
        <view class="description">{{item.description}}</view>
        <view class="action">
          <button class="button">试驾</button>
          <button class="button primary">了解更多</button>
        </view>
      </view>
    </swiper-item>
  </block>
</swiper>
<view class="cards">
  <view class="card" wx:for="{{vehicles}}" wx:key="id">
    <navigator hover-class="none" to="/pages/vehicles/show?id={{item.id}}">
    <image src="{{item.image}}" mode="aspectFill" />
    <view class="content">
      <view class="header">{{item.header}}
        <view class="sub-header">
          {{item.sub_header}}
        </view>
      </view>
      <view class="description">{{item.description}}</view>
      <view class="meta">{{item.meta.price}}</view>  
    </view>
    </navigator>
  </view>
</view>